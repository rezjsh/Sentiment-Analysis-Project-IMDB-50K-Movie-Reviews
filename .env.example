# Kaggle API credentials (required to download the dataset).
# Get these from https://www.kaggle.com/settings -> API -> Create New Token,
# which downloads a kaggle.json containing these two values.
# Alternative: place kaggle.json directly at ~/.kaggle/kaggle.json instead of using this file.
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
